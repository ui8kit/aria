{
  "name": "@ui8kit/aria",
  "version": "0.1.0",
  "description": "UI8Kit ARIA behavior layer with TypeScript and browser-compatible bundles",
  "license": "MIT",
  "author": "UI8Kit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "browser": "./dist/all.iife.js",
  "unpkg": "./dist/all.iife.js",
  "jsdelivr": "./dist/all.iife.js",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE",
    "docs/**",
    ".project/**"
  ],
  "scripts": {
    "build": "bunx tsup",
    "prepare": "bun run build",
    "typecheck": "bun run tsc --noEmit",
    "lint": "bunx eslint src tests playwright.config.ts vitest.config.ts tsup.config.ts",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "test": "bun run vitest run",
    "test:unit": "bun run test",
    "pretest:e2e": "bun run build",
    "test:e2e": "bunx playwright test",
    "test:a11y": "bunx playwright test --config playwright.config.ts --grep @a11y",
    "test:html": "bunx html-validate --config .htmlvalidate.json \"examples/**/*.html\"",
    "size": "bunx size-limit",
    "preflight": "bash ./scripts/preflight.sh",
    "sri": "node scripts/generate-sri.mjs",
    "docs-serve": "node scripts/serve-static.mjs --port 4173 --root .",
    "release": "bunx changeset publish"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./all": {
      "types": "./dist/all.d.ts",
      "browser": "./dist/all.iife.js",
      "import": "./dist/all.mjs",
      "require": "./dist/all.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.cjs"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.mjs",
      "require": "./dist/dialog.cjs"
    },
    "./accordion": {
      "types": "./dist/accordion.d.ts",
      "import": "./dist/accordion.mjs",
      "require": "./dist/accordion.cjs"
    },
    "./tabs": {
      "types": "./dist/tabs.d.ts",
      "import": "./dist/tabs.mjs",
      "require": "./dist/tabs.cjs"
    },
    "./combobox": {
      "types": "./dist/combobox.d.ts",
      "import": "./dist/combobox.mjs",
      "require": "./dist/combobox.cjs"
    },
    "./tooltip": {
      "types": "./dist/tooltip.d.ts",
      "import": "./dist/tooltip.mjs",
      "require": "./dist/tooltip.cjs"
    },
    "./alert": {
      "types": "./dist/alert.d.ts",
      "import": "./dist/alert.mjs",
      "require": "./dist/alert.cjs"
    },
    "./disclosure": {
      "types": "./dist/disclosure.d.ts",
      "import": "./dist/disclosure.mjs",
      "require": "./dist/disclosure.cjs"
    },
    "./menu": {
      "types": "./dist/menu.d.ts",
      "import": "./dist/menu.mjs",
      "require": "./dist/menu.cjs"
    },
    "./menubutton": {
      "types": "./dist/menubutton.d.ts",
      "import": "./dist/menubutton.mjs",
      "require": "./dist/menubutton.cjs"
    },
    "./listbox": {
      "types": "./dist/listbox.d.ts",
      "import": "./dist/listbox.mjs",
      "require": "./dist/listbox.cjs"
    },
    "./switch": {
      "types": "./dist/switch.d.ts",
      "import": "./dist/switch.mjs",
      "require": "./dist/switch.cjs"
    }
  },
  "sideEffects": [
    "**/*.css",
    "./dist/all.mjs",
    "./dist/all.cjs",
    "./dist/all.iife.js",
    "./dist/all.iife.min.js",
    "./dist/dialog.mjs",
    "./dist/dialog.cjs",
    "./dist/accordion.mjs",
    "./dist/accordion.cjs",
    "./dist/tabs.mjs",
    "./dist/tabs.cjs",
    "./dist/combobox.mjs",
    "./dist/combobox.cjs",
    "./dist/tooltip.mjs",
    "./dist/tooltip.cjs",
    "./dist/alert.mjs",
    "./dist/alert.cjs",
    "./dist/disclosure.mjs",
    "./dist/disclosure.cjs",
    "./dist/menu.mjs",
    "./dist/menu.cjs",
    "./dist/menubutton.mjs",
    "./dist/menubutton.cjs",
    "./dist/listbox.mjs",
    "./dist/listbox.cjs",
    "./dist/switch.mjs",
    "./dist/switch.cjs"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.10.3",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.47.2",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^20.14.2",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "html-validate": "^8.23.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.47.2",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.10",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.0",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "size-limit": [
    {
      "path": "dist/core.iife.min.js",
      "limit": "4kb"
    },
    {
      "path": "dist/all.iife.min.js",
      "limit": "22kb"
    }
  ]
}
